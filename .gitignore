# Dependencies
node_modules/
vendor/

# Build output
frontend/dist/
frontend/.vite/

# Environment files
.env
.env.local
.env.*.local
backend/.env
backend-node/.env
.sync-secrets

# SQLite databases — never version a database (it contains live PII + hashes).
# Production data is delivered at runtime via Postgres, not baked into git.
*.db
*.db-shm
*.db-wal
*.db-journal
*.sqlite
*.sqlite3

# Laravel
backend/bootstrap/cache/*.php
backend/storage/logs/*.log
backend/storage/framework/cache/
backend/storage/framework/sessions/
backend/storage/framework/views/

# macOS
.DS_Store

# IDE
.idea/
.vscode/
*.swp

# Railway / Vercel
.vercel/

# SQLite snapshot used by railway up direct deploys — not needed in git
# because Railway now uses PostgreSQL and the seeder runs from the container image
backend/database/portfolio_snapshot
