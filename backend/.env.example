APP_NAME=Laravel
APP_ENV=production
APP_KEY=
# SECURITY: Never set APP_DEBUG=true in production — leaks stack traces and config
APP_DEBUG=false
APP_URL=https://your-domain.example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# SOC 2 CC7.2 / ISO A.8.15: use daily rotation with 365-day retention
LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# Set to 'info' or 'warning' in production to reduce noise
LOG_LEVEL=info
LOG_DAILY_DAYS=365

# ── Database ──────────────────────────────────────────────────────────────────
# Production: PostgreSQL on Railway (set DB_CONNECTION=pgsql and fill in the
# values Railway provides under the database service's "Connect" tab).
# Local dev: SQLite is fine (keep DB_CONNECTION=sqlite, leave PG vars blank).
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=portfolio_manager
DB_USERNAME=postgres
DB_PASSWORD=

# Railway injects DATABASE_URL automatically when you add a Postgres service.
# Laravel's pgsql driver reads DB_URL if set, so you can use either approach:
#   DB_URL=${DATABASE_URL}
# OR set the individual vars above from Railway's connection details panel.

SESSION_DRIVER=database
# SECURITY: Reduce to 30 minutes for compliance (SOC 2 CC6.1 / ISO A.8.5)
SESSION_LIFETIME=30
# SECURITY: Always true in production — encrypts session data at rest
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# 'database' works on PostgreSQL (cache + cache_locks tables are in migrations).
# Switch to 'redis' if you add a Redis service for higher throughput.
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: php artisan jwt:secret
JWT_SECRET=
# SOC 2 CC6.1 / ISO A.8.5: keep access tokens short-lived (60 minutes)
JWT_TTL=60
# Refresh window: 1 week (ISO A.8.5 — limit long-lived credential exposure)
JWT_REFRESH_TTL=10080

# ─── Application secrets ──────────────────────────────────────────────────────
# SOC 2 CC6.7: must be set before enabling backup download endpoint
# Generate with: openssl rand -hex 32
BACKUP_TOKEN=

# Required for AI chat feature (ChatController)
OPENAI_API_KEY=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins, e.g.:
# FRONTEND_ORIGIN=https://app.example.com
FRONTEND_ORIGIN=http://localhost:5173
